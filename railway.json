{
    "build": {
        "builder": "NIXPACKS",
        "buildCommand": "cd backend && npm install && npm run build"
    },
    "deploy": {
        "startCommand": "cd backend && npm start",
        "healthcheckPath": "/api/v1/health",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
    }
}
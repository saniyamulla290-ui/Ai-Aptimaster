{
    "name": "aptimaster-backend",
    "version": "1.0.0",
    "description": "Backend API server for AptiMaster AI platform",
    "main": "dist/index.js",
    "scripts": {
        "start": "node dist/index.js",
        "dev": "nodemon src/index.ts",
        "build": "tsc",
        "test": "jest",
        "lint": "eslint src --ext .ts",
        "format": "prettier --write src/**/*.ts",
        "type-check": "tsc --noEmit"
    },
    "keywords": [
        "aptitude",
        "placement",
        "preparation",
        "ai",
        "education"
    ],
    "author": "AptiMaster Team",
    "license": "MIT",
    "dependencies": {
        "express": "^4.18.2",
        "mongoose": "^8.0.3",
        "bcryptjs": "^2.4.3",
        "jsonwebtoken": "^9.0.2",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "helmet": "^7.0.0",
        "compression": "^1.7.4",
        "express-rate-limit": "^7.1.5",
        "express-validator": "^7.0.1",
        "zod": "^3.22.4",
        "redis": "^4.6.12",
        "nodemailer": "^6.9.7",
        "winston": "^3.11.0",
        "multer": "^1.4.5-lts.1"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/node": "^20.10.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/cors": "^2.8.17",
        "@types/compression": "^1.7.5",
        "@types/multer": "^1.4.11",
        "typescript": "^5.3.2",
        "nodemon": "^3.0.2",
        "ts-node": "^10.9.2",
        "jest": "^29.7.0",
        "@types/jest": "^29.5.10",
        "ts-jest": "^29.1.1",
        "eslint": "^8.55.0",
        "@typescript-eslint/eslint-plugin": "^6.13.2",
        "@typescript-eslint/parser": "^6.13.2",
        "prettier": "^3.1.0"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}